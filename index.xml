      <guid>https://avendettaforyou.dev/irl/</guid>
      <description>&lt;div class=&#34;gallery-grid&#34;&gt;&#xD;&#xA;  &#xD;&#xA;  &#xD;&#xA;    &lt;a href=&#34;https://avendettaforyou.dev/img/irl/1.jpg&#34; class=&#34;lightbox&#34;&gt;&#xD;&#xA;      &lt;img&#xD;&#xA;        src=&#34;https://avendettaforyou.dev/img/irl/1.jpg&#34;&#xD;&#xA;         alt=&#34;1&#34; &#xD;&#xA;        class=&#34;gallery-img&#34;&#xD;&#xA;        &#xD;&#xA;      /&gt;&#xD;&#xA;    &lt;/a&gt;&#xD;&#xA;  &#xD;&#xA;  &#xD;&#xA;  &#xD;&#xA;  &#xD;&#xA;    &lt;div id=&#34;lightbox-modal&#34; onclick=&#34;this.style.display=&#39;none&#39;&#34;&gt;&#xD;&#xA;      &lt;img id=&#34;lightbox-img&#34; src=&#34;&#34; alt=&#34;Expanded Image&#34; /&gt;&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;  &#xD;&#xA;    &lt;style&gt;&#xD;&#xA;      div.gallery-grid {&#xD;&#xA;    display: grid;&#xD;&#xA;    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));&#xD;&#xA;    gap: 1.5rem;&#xD;&#xA;    padding: 1rem 0;&#xD;&#xA;  }&#xD;&#xA;  &#xD;&#xA;  div.gallery-grid a.lightbox img.gallery-img {&#xD;&#xA;    width: 100%;&#xD;&#xA;    height: 200px;&#xD;&#xA;    object-fit: cover;&#xD;&#xA;    border-radius: 12px;&#xD;&#xA;    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.1);&#xD;&#xA;    cursor: pointer;&#xD;&#xA;    transition: transform 0.3s ease, box-shadow 0.3s ease;&#xD;&#xA;  }&#xD;&#xA;  &#xD;&#xA;  div.gallery-grid a.lightbox img.gallery-img:hover {&#xD;&#xA;    transform: scale(1.05);&#xD;&#xA;    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);&#xD;&#xA;  }&#xD;&#xA;  &#xD;&#xA;   &#xD;&#xA;  #lightbox-modal {&#xD;&#xA;    display: none;&#xD;&#xA;    position: fixed;&#xD;&#xA;    z-index: 9999;&#xD;&#xA;    top: 0;&#xD;&#xA;    left: 0;&#xD;&#xA;    width: 100%;&#xD;&#xA;    height: 100%;&#xD;&#xA;    background: rgba(0, 0, 0, 0.85);&#xD;&#xA;    align-items: center;&#xD;&#xA;    justify-content: center;&#xD;&#xA;    animation: fadeIn 0.3s ease forwards;&#xD;&#xA;  }&#xD;&#xA;  &#xD;&#xA;  #lightbox-modal img {&#xD;&#xA;    max-width: 90%;&#xD;&#xA;    max-height: 90%;&#xD;&#xA;    border-radius: 12px;&#xD;&#xA;    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);&#xD;&#xA;  }&#xD;&#xA;  &#xD;&#xA;  @keyframes fadeIn {&#xD;&#xA;    from {&#xD;&#xA;      opacity: 0;&#xD;&#xA;    }&#xD;&#xA;    to {&#xD;&#xA;      opacity: 1;&#xD;&#xA;    }&#xD;&#xA;  }&#xD;&#xA;  &#xD;&#xA;    &lt;/style&gt;&#xD;&#xA;  &#xD;&#xA;    &lt;script&gt;&#xD;&#xA;      document.addEventListener(&#34;DOMContentLoaded&#34;, function () {&#xD;&#xA;        document.querySelectorAll(&#34;.lightbox&#34;).forEach((link) =&gt; {&#xD;&#xA;          link.addEventListener(&#34;click&#34;, function (e) {&#xD;&#xA;            e.preventDefault();&#xD;&#xA;            const src = this.getAttribute(&#34;href&#34;);&#xD;&#xA;            const modal = document.getElementById(&#34;lightbox-modal&#34;);&#xD;&#xA;            const modalImg = document.getElementById(&#34;lightbox-img&#34;);&#xD;&#xA;            modalImg.src = src;&#xD;&#xA;            modal.style.display = &#34;flex&#34;;&#xD;&#xA;          });&#xD;&#xA;        });&#xD;&#xA;  &#xD;&#xA;        const modal = document.getElementById(&#34;lightbox-modal&#34;);&#xD;&#xA;        modal.addEventListener(&#34;click&#34;, function () {&#xD;&#xA;          this.style.display = &#34;none&#34;;&#xD;&#xA;          const modalImg = document.getElementById(&#34;lightbox-img&#34;);&#xD;&#xA;          modalImg.src = &#34;&#34;;&#xD;&#xA;        });&#xD;&#xA;      });&#xD;&#xA;    &lt;/script&gt;&#xD;&#xA;  &#xD;&#xA;    &#xD;&#xA;  &#xD;&#xA;&#xD;&#xA;  &#xD;&#xA;    &lt;a href=&#34;https://avendettaforyou.dev/img/irl/2.jpg&#34; class=&#34;lightbox&#34;&gt;&#xD;&#xA;      &lt;img&#xD;&#xA;        src=&#34;https://avendettaforyou.dev/img/irl/2.jpg&#34;&#xD;&#xA;         alt=&#34;2&#34; &#xD;&#xA;        class=&#34;gallery-img&#34;&#xD;&#xA;        &#xD;&#xA;      /&gt;&#xD;&#xA;    &lt;/a&gt;&#xD;&#xA;  &#xD;&#xA;  &#xD;&#xA;  &#xD;&#xA;  &#xD;&#xA;&#xD;&#xA;  &#xD;&#xA;    &lt;a href=&#34;https://avendettaforyou.dev/img/irl/3.jpg&#34; class=&#34;lightbox&#34;&gt;&#xD;&#xA;      &lt;img&#xD;&#xA;        src=&#34;https://avendettaforyou.dev/img/irl/3.jpg&#34;&#xD;&#xA;         alt=&#34;3&#34; &#xD;&#xA;        class=&#34;gallery-img&#34;&#xD;&#xA;        &#xD;&#xA;      /&gt;&#xD;&#xA;    &lt;/a&gt;&#xD;&#xA;  &#xD;&#xA;  &#xD;&#xA;  &#xD;&#xA;  &#xD;&#xA;&#xD;&#xA;  &#xD;&#xA;    &lt;a href=&#34;https://avendettaforyou.dev/img/irl/4.jpg&#34; class=&#34;lightbox&#34;&gt;&#xD;&#xA;      &lt;img&#xD;&#xA;        src=&#34;https://avendettaforyou.dev/img/irl/4.jpg&#34;&#xD;&#xA;         alt=&#34;4&#34; &#xD;&#xA;        class=&#34;gallery-img&#34;&#xD;&#xA;        &#xD;&#xA;      /&gt;&#xD;&#xA;    &lt;/a&gt;&#xD;&#xA;  &#xD;&#xA;  &#xD;&#xA;  &#xD;&#xA;  &#xD;&#xA;&#xD;&#xA;  &#xD;&#xA;    &lt;a href=&#34;https://avendettaforyou.dev/img/irl/5.jpg&#34; class=&#34;lightbox&#34;&gt;&#xD;&#xA;      &lt;img&#xD;&#xA;        src=&#34;https://avendettaforyou.dev/img/irl/5.jpg&#34;&#xD;&#xA;         alt=&#34;5&#34; &#xD;&#xA;        class=&#34;gallery-img&#34;&#xD;&#xA;        &#xD;&#xA;      /&gt;&#xD;&#xA;    &lt;/a&gt;&#xD;&#xA;  &#xD;&#xA;  &#xD;&#xA;  &#xD;&#xA;  &#xD;&#xA;&#xD;&#xA;  &#xD;&#xA;    &lt;a href=&#34;https://avendettaforyou.dev/img/irl/6.jpg&#34; class=&#34;lightbox&#34;&gt;&#xD;&#xA;      &lt;img&#xD;&#xA;        src=&#34;https://avendettaforyou.dev/img/irl/6.jpg&#34;&#xD;&#xA;         alt=&#34;6&#34; &#xD;&#xA;        class=&#34;gallery-img&#34;&#xD;&#xA;        &#xD;&#xA;      /&gt;&#xD;&#xA;    &lt;/a&gt;&#xD;&#xA;  &#xD;&#xA;  &#xD;&#xA;  &#xD;&#xA;  &#xD;&#xA;&#xD;&#xA;  &#xD;&#xA;    &lt;a href=&#34;https://avendettaforyou.dev/img/irl/7.jpg&#34; class=&#34;lightbox&#34;&gt;&#xD;&#xA;      &lt;img&#xD;&#xA;        src=&#34;https://avendettaforyou.dev/img/irl/7.jpg&#34;&#xD;&#xA;         alt=&#34;7&#34; &#xD;&#xA;        class=&#34;gallery-img&#34;&#xD;&#xA;        &#xD;&#xA;      /&gt;&#xD;&#xA;    &lt;/a&gt;&#xD;&#xA;  &#xD;&#xA;  &#xD;&#xA;  &#xD;&#xA;  &#xD;&#xA;&#xD;&